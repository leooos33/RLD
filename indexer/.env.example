# RLD Indexer Development Environment

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=rld
DB_PASSWORD=rld_dev_password
DB_NAME=rld_indexer

# RPC
RPC_URL=http://localhost:8545
# WS_RPC_URL=ws://localhost:8546

# Chain
CHAIN_ID=11155111
FINALITY_BLOCKS=12
START_BLOCK=0

# Contract Addresses (set these after deployment)
RLD_CORE_ADDRESS=
BROKER_FACTORY_ADDRESS=
POOL_MANAGER_ADDRESS=
POSM_ADDRESS=
TWAMM_ADDRESS=

# Safety Settings
RECONCILE_BLOCKS=100
DUAL_SOURCE_MODE=true

# Operating Mode
READ_ONLY_MODE=true
LIQUIDATION_ENABLED=false

# Logging
LOG_LEVEL=INFO
