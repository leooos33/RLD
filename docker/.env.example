# ═══════════════════════════════════════════════════════════════
# RLD Simulation Stack — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Required: Anvil RPC (already running externally)
RPC_URL=http://host.docker.internal:8545

# Required: Alchemy/Infura URL (for forge fork verification)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required: operator keys (use unique non-public keys in any shared environment)
DEPLOYER_KEY=replace_with_private_key
USER_A_KEY=replace_with_private_key
USER_B_KEY=replace_with_private_key
USER_C_KEY=replace_with_private_key
MM_KEY=replace_with_private_key
CHAOS_KEY=replace_with_private_key

# Optional: Chaos trader runtime tuning
CHAOS_AUTO_FUND=true
CHAOS_AUTO_FUND_COOLDOWN_SEC=90
CHAOS_TRADE_INTERVAL_MIN=10
CHAOS_TRADE_INTERVAL_MAX=15
CHAOS_TRADE_PCT_MIN=0.01
CHAOS_TRADE_PCT_MAX=0.10
CHAOS_MIN_WAUSDC_FOR_BUY=100
CHAOS_MIN_WRLP_FOR_SELL=1
CHAOS_MIN_BUY_AMOUNT_WAUSDC=50
CHAOS_MIN_SELL_AMOUNT_WRLP=1

# Optional: Rate/analytics API (canonical)
RATES_API_BASE_URL=http://host.docker.internal:5000
RATES_API_PORT=5000

# Compatibility aliases (deprecated; retained for one migration window)
API_URL=http://host.docker.internal:5000
ENVIO_API_URL=http://host.docker.internal:5000
RATES_API_URL=http://host.docker.internal:5000
ENVIO_PORT=5000
ENVIO_API_PORT=5000
# Deprecation timeline for legacy analytics alias (/envio-graphql)
ENVIO_GRAPHQL_ALIAS_SUNSET=Wed, 31 Dec 2026 00:00:00 GMT

# Optional: Rate oracle API
API_KEY=your_api_key_here
MIN_BORROW_APY=0.0
MAX_BORROW_APY=2.0
MAX_RATE_AGE_SECONDS=900
REQUIRE_RATE_TIMESTAMP=true
RATES_TIMEOUT=2

# Optional: Indexer port (host-side)
INDEXER_PORT=8080

# PostgreSQL (sim-indexer database)
DB_PASSWORD=replace_with_strong_password
DB_PORT=5432

# Required: admin reset protection token
INDEXER_ADMIN_TOKEN=replace_with_long_random_token
INDEXER_ALLOW_UNSAFE_ADMIN_RESET=false
INDEXER_ADMIN_INTERNAL_ONLY=true
INDEXER_ADMIN_ALLOWED_CLIENTS=127.0.0.1,::1,localhost,172.20.0.1,172.17.0.1
INDEXER_EXPOSE_INTERNAL_ERRORS=false

# Optional: explicit frontend origins for GraphQL APIs
INDEXER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rld.fi,https://www.rld.fi
ENVIO_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rld.fi,https://www.rld.fi
RATES_API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rld.fi,https://www.rld.fi
FAUCET_CORS_ORIGIN=https://rld.fi
DASHBOARD_CORS_ORIGIN=https://rld.fi

# ClickHouse auth (required if clickhouse stack is enabled)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=replace_with_strong_password
CLICKHOUSE_ASYNC_INSERT=true
CLICKHOUSE_WAIT_FOR_ASYNC_INSERT=true
CLICKHOUSE_MUTATION_REWRITE_ENABLED=false

# Reth RPC CORS policy for browser clients
RETH_HTTP_CORS_DOMAIN=http://localhost:3000,http://localhost:5173,https://rld.fi,https://www.rld.fi
RETH_MAINNET_HTTP_CORS_DOMAIN=http://localhost:3000,http://localhost:5173,https://rld.fi,https://www.rld.fi
SIM_ID=default
